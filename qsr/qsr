#!/usr/bin/env ruby
# qsr - Quasar System Resources

require 'optparse'
require 'fileutils'

DEFAULT_STRATA = "hijacked"
VERSION = "0.1.3"
$auto_confirm = false
QUASAR_REPO_URL = "https://github.com/z3nnix/QuasarLinux.git"
QUASAR_REPO_PATH = "/opt/quasar"

# ----------------------------------------------------------------------
# Helpers
# ----------------------------------------------------------------------

def show_help
  puts <<~HELP
    Quasar System Resources (qsr) v#{VERSION}
    Package and strata management for Quasar Linux

    Usage:
      qsr [options] <command> [arguments...]

    Commands:
      install <pkg> [pkg2 pkg3 ...]   Install packages into current strata
      install <strata>:<pkg> [...]    Install packages into specified strata
      remove  <pkg> [pkg2 pkg3 ...]   Remove packages from current strata
      remove  <strata>:<pkg> [...]    Remove packages from specified strata
      update                      Update entire system
      update  <pkg>               Update specific package
      update  <strata>:<pkg>      Update package in specified strata
      doctor                      Run system diagnostics
      list                        List all installed packages
      list <strata>               List packages in specified strata
      info  <pkg>                 Show package information

    Options:
      -h, --help                  Show help message
      -v, --version               Show version information
      -y, --yes                   Auto-confirm all prompts

    Examples:
      qsr install nginx redis postgresql   Install multiple packages
      qsr install deb:steam wine           Install steam to debian strata and wine to current
      qsr remove  deb:steam wine           Remove steam from debian strata and wine from current
      qsr update  firefox                  Update firefox package only
  HELP
end

def confirm(prompt, default = false)
  return true if $auto_confirm
  print "#{prompt} "
  answer = STDIN.gets.chomp.downcase
  if default
    answer.empty? || answer == 'y' || answer == 'yes'
  else
    answer == 'y' || answer == 'yes'
  end
end

def run_command(cmd, show_exec = false)
  puts ":: executing: #{cmd}" if show_exec
  system(cmd)
  unless $?.success?
    puts "error: command failed with exit code #{$?.exitstatus}"
    exit $?.exitstatus
  end
end

def normalize_strata_name(strata)
  return "debian" if strata == "deb"
  strata
end

def strata_exists?(strata)
  real_name = normalize_strata_name(strata)
  output = `brl list 2>/dev/null`
  output.split.include?(real_name)
end

def ensure_strata(strata)
  real_name = normalize_strata_name(strata)
  return true if strata_exists?(real_name)
  
  if real_name == "debian"
    puts ":: strata 'debian' not found, fetching..."
    if confirm(":: Fetch debian strata? [Y/n]", true)
      run_command("brl fetch debian")
      return strata_exists?(real_name)
    end
  end
  false
end

def parse_strata_package(arg)
  if arg.include?(':')
    parts = arg.split(':', 2)
    [parts[0], parts[1]]
  else
    [nil, arg]
  end
end

def group_packages_by_strata(packages)
  groups = {}
  
  packages.each do |pkg|
    strata, pkg_name = parse_strata_package(pkg)
    normalized_strata = strata ? normalize_strata_name(strata) : DEFAULT_STRATA
    
    groups[normalized_strata] ||= []
    groups[normalized_strata] << pkg_name
  end
  
  groups
end

def get_package_manager(strata)
  strata == "debian" ? "apt" : "pacman"
end

def handle_multi_packages(packages, action_desc, needs_confirmation: true)
  if packages.nil? || packages.empty?
    puts "error: no package specified for #{action_desc}"
    puts "usage: qsr #{action_desc.split[0]} <package> [package2 ...] or qsr #{action_desc.split[0]} <strata>:<package> [...]"
    exit 1
  end

  groups = group_packages_by_strata(packages)
  
  puts ":: #{action_desc} packages..."
  groups.each do |strata, pkgs|
    puts "  -> strata '#{strata}': #{pkgs.join(', ')}"
  end
  
  if needs_confirmation && !confirm(":: Proceed with #{action_desc}? [Y/n]", true)
    puts ":: cancelled."
    exit 0
  end

  groups.each do |strata, pkgs|
    unless strata_exists?(strata)
      puts "error: strata '#{strata}' does not exist"
      puts "available stratas:"
      system("brl list")
      exit 1
    end
    
    puts "\n:: #{action_desc} from strata '#{strata}': #{pkgs.join(', ')}"
    
    if get_package_manager(strata) == "apt"
      case action_desc
      when /installing/
        run_command("strat #{strata} apt update")
        run_command("strat #{strata} apt install -y #{pkgs.join(' ')}")
      when /removing/
        run_command("strat #{strata} apt remove -y #{pkgs.join(' ')}")
      end
    else
      case action_desc
      when /installing/
        run_command("strat #{strata} pacman -Syu --noconfirm #{pkgs.join(' ')}")
      when /removing/
        run_command("strat #{strata} pacman -R --noconfirm #{pkgs.join(' ')}")
      end
    end
  end
  
  puts "\n:: done."
end

# ----------------------------------------------------------------------
# Repository Management
# ----------------------------------------------------------------------

def clone_or_update_quasar_repo
  unless Dir.exist?(QUASAR_REPO_PATH)
    puts ":: cloning Quasar repository..."
    parent_dir = File.dirname(QUASAR_REPO_PATH)
    FileUtils.mkdir_p(parent_dir) unless Dir.exist?(parent_dir)
    
    if system("git clone --quiet #{QUASAR_REPO_URL} #{QUASAR_REPO_PATH}")
      puts ":: repository cloned successfully"
      return true
    else
      puts "error: failed to clone repository"
      return false
    end
  end
  
  unless File.directory?(File.join(QUASAR_REPO_PATH, ".git"))
    puts "warning: #{QUASAR_REPO_PATH} exists but is not a git repository"
    return false
  end
  
  puts ":: updating Quasar repository..."
  
  unless system("cd #{QUASAR_REPO_PATH} && git fetch --all --prune --quiet")
    puts "error: git fetch failed"
    return false
  end
  
  status_output = `cd #{QUASAR_REPO_PATH} && git status --porcelain`
  unless status_output.empty?
    system("cd #{QUASAR_REPO_PATH} && git stash push --quiet -m 'qsr auto-stash before update'")
  end
  
  if system("cd #{QUASAR_REPO_PATH} && git pull --ff-only --quiet")
    puts ":: repository updated successfully"
    return true
  else
    puts "error: git pull failed"
    return false
  end
end

def sync_rootfs
  rootfs_dir = File.join(QUASAR_REPO_PATH, "rootfs")
  unless Dir.exist?(rootfs_dir)
    puts "warning: #{rootfs_dir} not found, skipping rootfs sync"
    return false
  end
  
  files_count = `find #{rootfs_dir} -type f 2>/dev/null | wc -l`.chomp.to_i
  
  if files_count == 0
    puts "warning: no files found in rootfs, skipping sync"
    return false
  end
  
  puts ":: syncing rootfs (#{files_count} files)..."
  
  rsync_cmd = "rsync -a --no-owner --no-group --quiet --exclude='.git*' #{rootfs_dir}/ /"
  
  if system(rsync_cmd)
    puts ":: rootfs sync completed"
    return true
  else
    puts "error: rootfs sync failed"
    return false
  end
end

# ----------------------------------------------------------------------
# Self-update
# ----------------------------------------------------------------------

def handle_self_update
  current_path = `/usr/bin/which qsr`.chomp
  current_path = $0 if current_path.empty? || current_path == ""
  
  if current_path.empty?
    puts "error: cannot determine qsr binary location"
    return false
  end
  
  temp_file = "/tmp/qsr_new_#{Time.now.to_i}"
  
  download_cmd = "curl -s -o #{temp_file} https://raw.githubusercontent.com/z3nnix/quasarlinux/main/qsr/qsr"
  system(download_cmd)
  
  unless $?.success? && File.exist?(temp_file) && File.size(temp_file) > 0
    puts "error: failed to download new version"
    File.delete(temp_file) if File.exist?(temp_file)
    return false
  end
  
  unless File.read(temp_file).include?("qsr - Quasar System Resources")
    puts "error: downloaded file appears to be invalid"
    File.delete(temp_file) if File.exist?(temp_file)
    return false
  end
  
  updater_script = <<~SCRIPT
    #!/bin/bash
    sleep 1
    cp #{temp_file} #{current_path}
    chmod +x #{current_path}
    rm -f #{temp_file}
  SCRIPT
  
  updater_path = "/tmp/qsr_updater_#{Time.now.to_i}.sh"
  File.write(updater_path, updater_script)
  File.chmod(0755, updater_path)
  
  system("nohup bash #{updater_path} > /dev/null 2>&1 &")
  return true
end

# ----------------------------------------------------------------------
# Command Handlers
# ----------------------------------------------------------------------

def handle_install(packages)
  handle_multi_packages(packages, "installing", needs_confirmation: true)
end

def handle_remove(packages)
  handle_multi_packages(packages, "removing", needs_confirmation: true)
end

def handle_update(package = nil)
  if package.nil?
    puts ":: updating system packages..."
    run_command("strat #{DEFAULT_STRATA} pacman -Syu --noconfirm")
    
    if strata_exists?("debian")
      puts ":: updating debian strata..."
      run_command("strat debian apt update")
      run_command("strat debian apt upgrade -y")
    end
    
    puts ":: updating bedrock Linux..."
    run_command("brl update")
    
    if clone_or_update_quasar_repo
      sync_rootfs
    end
    
    puts ":: updating qsr..."
    handle_self_update
    
    puts ":: system update completed"
    return
  end

  strata, pkg = parse_strata_package(package)
  if strata
    real_strata = normalize_strata_name(strata)
    unless strata_exists?(real_strata)
      puts "error: strata '#{real_strata}' does not exist"
      puts "available stratas:"
      system("brl list")
      exit 1
    end
    
    if get_package_manager(real_strata) == "apt"
      puts ":: updating #{pkg} in #{real_strata}..."
      run_command("strat #{real_strata} apt update")
      run_command("strat #{real_strata} apt upgrade -y #{pkg}")
    else
      puts ":: updating #{pkg} in #{real_strata}..."
      run_command("strat #{real_strata} pacman -Syu --noconfirm #{pkg}")
    end
  else
    puts ":: updating #{pkg}..."
    run_command("strat #{DEFAULT_STRATA} pacman -Syu --noconfirm #{pkg}")
  end
end

def handle_list(strata = nil)
  if strata.nil?
    puts ":: listing installed packages..."
    run_command("strat #{DEFAULT_STRATA} pacman -Q")
  else
    real_strata = normalize_strata_name(strata)
    unless strata_exists?(real_strata)
      puts "error: strata '#{real_strata}' does not exist"
      puts "available stratas:"
      system("brl list")
      exit 1
    end
    
    puts ":: listing packages in strata #{real_strata}..."
    if get_package_manager(real_strata) == "apt"
      run_command("strat #{real_strata} dpkg -l")
    else
      run_command("strat #{real_strata} pacman -Q")
    end
  end
end

def handle_info(package)
  if package.nil?
    puts "error: no package specified"
    puts "usage: qsr info <package>"
    exit 1
  end

  strata, pkg = parse_strata_package(package)
  if strata
    real_strata = normalize_strata_name(strata)
    unless strata_exists?(real_strata)
      puts "error: strata '#{real_strata}' does not exist"
      puts "available stratas:"
      system("brl list")
      exit 1
    end
    
    puts ":: showing info for #{pkg} in strata #{real_strata}..."
    if get_package_manager(real_strata) == "apt"
      run_command("strat #{real_strata} apt show #{pkg}")
    else
      run_command("strat #{real_strata} pacman -Qi #{pkg}")
    end
  else
    puts ":: showing info for #{pkg}..."
    run_command("strat #{DEFAULT_STRATA} pacman -Qi #{pkg}")
  end
end

def handle_doctor
  puts ":: running system diagnostics..."
  
  unless system("which strat > /dev/null 2>&1")
    puts "error: 'strat' command not found. Is Bedrock Linux installed?"
    exit 1
  end

  unless strata_exists?(DEFAULT_STRATA)
    puts "warning: strata '#{DEFAULT_STRATA}' not found"
    puts ":: available stratas:"
    system("brl list")
    exit 1
  end

  puts ":: checking arch package manager..."
  run_command("strat #{DEFAULT_STRATA} pacman -Q")
  
  if strata_exists?("debian")
    puts ":: checking debian package manager..."
    run_command("strat debian dpkg -l | head -5")
  end
  
  if Dir.exist?(QUASAR_REPO_PATH)
    if File.directory?(File.join(QUASAR_REPO_PATH, ".git"))
      version = `cd #{QUASAR_REPO_PATH} && git rev-parse --short HEAD 2>/dev/null`.chomp
      puts ":: Quasar repository: #{version}" unless version.empty?
    end
  end

  puts ":: system healthy"
end

# ----------------------------------------------------------------------
# Argument Parser
# ----------------------------------------------------------------------

def parse_arguments
  opt_parser = OptionParser.new do |opts|
    opts.on("-h", "--help", "Show help") do
      show_help
      exit 0
    end
    opts.on("-v", "--version", "Show version") do
      puts "qsr #{VERSION}"
      exit 0
    end
    opts.on("-y", "--yes", "Auto-confirm all prompts") do
      $auto_confirm = true
    end
  end

  begin
    opt_parser.parse!(ARGV)
  rescue OptionParser::InvalidOption => e
    puts "error: #{e.message}"
    puts "See 'qsr --help' for usage"
    exit 1
  end

  if ARGV.empty?
    show_help
    exit 0
  end

  command = ARGV.shift

  case command
  when "install"
    handle_install(ARGV)
  when "remove"
    handle_remove(ARGV)
  when "update"
    handle_update(ARGV.shift)
  when "list"
    handle_list(ARGV.shift)
  when "info"
    handle_info(ARGV.shift)
  when "doctor"
    handle_doctor
  else
    puts "qsr: '#{command}' is not a valid command"
    puts "See 'qsr --help' for more information"
    exit 1
  end
end

# ----------------------------------------------------------------------
# Run
# ----------------------------------------------------------------------

if __FILE__ == $0
  parse_arguments
end