#!/usr/bin/env ruby
# qsr - Quasar System Resources

require 'optparse'

DEFAULT_STRATA = "hijacked"
VERSION = "0.1.0"
$auto_confirm = false

# ----------------------------------------------------------------------
# Helpers
# ----------------------------------------------------------------------

def show_help
  puts <<~HELP
    Quasar System Resources (qsr) v#{VERSION}
    Package and strata management for Quasar Linux

    Usage:
      qsr [options] <command> [arguments]

    Commands:
      install <pkg>               Install package into current strata
      install <strata>:<pkg>      Install package into specified strata
      remove  <pkg>               Remove package from current strata
      remove  <strata>:<pkg>      Remove package from specified strata
      update                      Update entire system
      update  <pkg>               Update specific package
      update  <strata>:<pkg>      Update package in specified strata
      doctor                      Run system diagnostics
      list                        List all installed packages
      list <strata>               List packages in specified strata
      info  <pkg>                 Show package information

    Options:
      -h, --help                  Show this help message
      -v, --version               Show version information
      -y, --yes                   Auto-confirm all prompts

    Examples:
      qsr install nginx               Install nginx to current strata
      qsr install deb:steam           Install steam to debian strata
      qsr remove  deb:steam           Remove steam from debian strata
      qsr update  firefox             Update firefox package only
  HELP
end

def confirm(prompt, default = false)
  return true if $auto_confirm
  print "#{prompt} "
  answer = STDIN.gets.chomp.downcase
  if default
    answer.empty? || answer == 'y' || answer == 'yes'
  else
    answer == 'y' || answer == 'yes'
  end
end

def run_command(cmd, show_exec = true)
  puts ":: executing: #{cmd}" if show_exec
  system(cmd)
  unless $?.success?
    puts "error: command failed with exit code #{$?.exitstatus}"
    exit $?.exitstatus
  end
end

# Parses "strata:package" or just "package"
# Returns [strata, package, has_strata_flag]
def parse_strata_package(arg)
  if arg.include?(':')
    arg.split(':', 2)
  else
    [nil, arg]
  end
end

# For read-only commands we rarely need confirmation, but for fallback we do.
def with_fallback(action_desc, target_strata, pkg, default_strata = DEFAULT_STRATA, &block)
  puts ":: #{action_desc} #{pkg} from strata #{target_strata}..."
  puts "NOTE: Multi-strata operations are not yet implemented\n"
  if confirm(":: Proceed with fallback to current strata (#{default_strata})? [y/N]", false)
    yield(pkg)
  else
    puts ":: cancelled."
    exit 0
  end
end

# Generic handler for commands that support strata:package syntax with fallback
def handle_with_fallback(package, action_desc, command_fmt, needs_confirmation: true)
  if package.nil?
    puts "error: no package specified for #{action_desc}"
    puts "usage: qsr #{action_desc.split[0]} <package> or qsr #{action_desc.split[0]} <strata>:<package>"
    exit 1
  end

  strata, pkg = parse_strata_package(package)

  if strata
    with_fallback(action_desc, strata, pkg) do |pk|
      cmd = format(command_fmt, pk)
      if needs_confirmation && confirm(":: Proceed with #{action_desc}? [Y/n]", true)
        run_command(cmd)
      elsif !needs_confirmation
        run_command(cmd)
      else
        puts ":: cancelled."
        exit 0
      end
    end
  else
    puts ":: #{action_desc} #{pkg} into current strata (#{DEFAULT_STRATA})..."
    cmd = format(command_fmt, pkg)
    if needs_confirmation
      if confirm(":: Proceed with #{action_desc}? [Y/n]", true)
        run_command(cmd)
      else
        puts ":: cancelled."
        exit 0
      end
    else
      run_command(cmd)
    end
  end
  puts "done."
end

# ----------------------------------------------------------------------
# Command handlers
# ----------------------------------------------------------------------

def handle_install(package)
  handle_with_fallback(package, "installing", "strat #{DEFAULT_STRATA} pacman -Syu --noconfirm %s", needs_confirmation: true)
end

def handle_remove(package)
  handle_with_fallback(package, "removing", "strat #{DEFAULT_STRATA} pacman -R --noconfirm %s", needs_confirmation: true)
end

def handle_update(package = nil)
  if package.nil?
    puts ":: updating entire system..."
    if confirm(":: Proceed with full system update? [Y/n]", true)
      run_command("strat #{DEFAULT_STRATA} pacman -Syu --noconfirm")
      run_command("brl update")
    else
      puts ":: cancelled."
      exit 0
    end
    puts "done."
    return
  end

  strata, pkg = parse_strata_package(package)
  if strata
    with_fallback("updating", strata, pkg) do |pk|
      if confirm(":: Proceed with update? [Y/n]", true)
        run_command("strat #{DEFAULT_STRATA} pacman -Syu --noconfirm #{pk}")
      else
        puts ":: cancelled."
        exit 0
      end
    end
  else
    puts ":: updating #{pkg} in current strata..."
    if confirm(":: Proceed with update? [Y/n]", true)
      run_command("strat #{DEFAULT_STRATA} pacman -Syu --noconfirm #{pkg}")
    else
      puts ":: cancelled."
      exit 0
    end
  end
  puts "done."
end

def handle_list(strata = nil)
  if strata.nil?
    puts ":: listing all installed packages in current strata (#{DEFAULT_STRATA})..."
    run_command("strat #{DEFAULT_STRATA} pacman -Q")
  else
    puts ":: listing packages in strata #{strata}..."
    puts "NOTE: Listing packages from other strata is not yet implemented\n"
    puts ":: This feature will be available in a future version"
    exit 1
  end
  puts "done."
end

def handle_info(package)
  if package.nil?
    puts "error: no package specified"
    puts "usage: qsr info <package>"
    exit 1
  end

  strata, pkg = parse_strata_package(package)
  if strata
    puts ":: showing info for #{pkg} in strata #{strata}..."
    puts "NOTE: Multi-strata package info is not yet implemented\n"
    if confirm(":: Show info from current strata instead? [y/N]", false)
      run_command("strat #{DEFAULT_STRATA} pacman -Qi #{pkg}")
    else
      puts ":: cancelled."
      exit 0
    end
  else
    puts ":: showing info for #{pkg}..."
    run_command("strat #{DEFAULT_STRATA} pacman -Qi #{pkg}")
  end
  puts "done."
end

def handle_doctor
  puts ":: running system diagnostics..."
  # No confirmation needed for read-only diagnostic

  puts ":: checking strata integrity..."
  unless system("which strat > /dev/null 2>&1")
    puts "error: 'strat' command not found. Is Bedrock Linux installed?"
    exit 1
  end

  unless system("strat -l | grep -q '^#{DEFAULT_STRATA}$'")
    puts "warning: strata '#{DEFAULT_STRATA}' not found"
    puts ":: available stratas:"
    system("strat -l")
    exit 1
  end

  puts ":: checking package manager..."
  run_command("strat #{DEFAULT_STRATA} pacman -Q")

  puts ":: all checks passed. System appears healthy."
end

# ----------------------------------------------------------------------
# Argument parser
# ----------------------------------------------------------------------

def parse_arguments
  opt_parser = OptionParser.new do |opts|
    opts.on("-h", "--help", "Show help") do
      show_help
      exit 0
    end
    opts.on("-v", "--version", "Show version") do
      puts "qsr #{VERSION}"
      exit 0
    end
    opts.on("-y", "--yes", "Auto-confirm all prompts") do
      $auto_confirm = true
    end
  end

  begin
    opt_parser.parse!(ARGV)
  rescue OptionParser::InvalidOption => e
    puts "error: #{e.message}"
    puts "See 'qsr --help' for usage"
    exit 1
  end

  if ARGV.empty?
    show_help
    exit 0
  end

  command = ARGV.shift

  case command
  when "install"  then handle_install(ARGV.shift)
  when "remove"   then handle_remove(ARGV.shift)
  when "update"   then handle_update(ARGV.shift)
  when "list"     then handle_list(ARGV.shift)
  when "info"     then handle_info(ARGV.shift)
  when "doctor"   then handle_doctor
  else
    puts "qsr: '#{command}' is not a valid command"
    puts "See 'qsr --help' for more information"
    exit 1
  end
end

# ----------------------------------------------------------------------
# Run
# ----------------------------------------------------------------------

if __FILE__ == $0
  parse_arguments
end